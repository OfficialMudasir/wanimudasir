# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_CLARITY_PROJECT_ID=your-clarity-project-id

# Build paths
# BASE_PATH=/           (godaddy / Vercel production)
# BASE_PATH=/wanimudasir/ (GitHub Pages)

# Contact form — SMTP (set in Vercel → Project → Settings → Environment Variables)
# Gmail example (free): enable 2FA, create an App Password at https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=wanimudasir312@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_TO=wanimudasir312@gmail.com
# SMTP_FROM=wanimudasir312@gmail.com

# Brevo (Sendinblue) free tier alternative:
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-brevo-login-email
# SMTP_PASS=your-brevo-smtp-key
